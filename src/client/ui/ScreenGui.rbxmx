			<Item class="LocalScript" referent="RBX216E735359B54F118531362DAB586AB2">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local player = game.Players.LocalPlayer
local zoneText = script.Parent

player:GetAttributeChangedSignal("Zone"):Connect(function()

	local zone = player:GetAttribute("Zone")

	if zone then
		zoneText.Text = "Zone: "..zone
	end

end)
]]></ProtectedString>
