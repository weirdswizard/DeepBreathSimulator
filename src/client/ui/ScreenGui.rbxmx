			<Item class="LocalScript" referent="RBX3EF7E8864F5044F488BA0DF4B8B0DD39">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local player = game.Players.LocalPlayer
local button = script.Parent
local event = game.ReplicatedStorage:WaitForChild("UpgradeBreath")

local upgradeCosts = {
	200,
	500,
	1200,
	2500
}

local function updateButton()

	local level = player.Upgrades.BreathLevel.Value

	if level >= 5 then
		button.Text = "MAX UPGRADE"
	else
		button.Text = "Upgrade Breath\nCost: "..upgradeCosts[level]
	end

end

button.MouseButton1Click:Connect(function()

	event:FireServer()

end)

player.Upgrades.BreathLevel.Changed:Connect(updateButton)

updateButton()]]></ProtectedString>
