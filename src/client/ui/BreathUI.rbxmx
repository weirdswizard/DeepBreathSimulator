			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">BreathUI</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
		<Item class="LocalScript" referent="RBX45523CEFAAF04967BB048AC003272F77">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local player = game.Players.LocalPlayer

local breathFill = script.Parent.BreathBarBackground:WaitForChild("BreathFill")
local depthText = script.Parent:WaitForChild("DepthText")
local rewardText = script.Parent:WaitForChild("RewardText")
local breathText = script.Parent.BreathBarBackground:WaitForChild("BreathText")

-- function to calculate max breath
local function getMaxBreath()

	local upgrades = player:FindFirstChild("Upgrades")

	if upgrades then
		local level = upgrades.BreathLevel.Value
		return 100 + (level - 1) * 30
	end

	return 100
end


-- Breath UI
player:GetAttributeChangedSignal("Breath"):Connect(function()

	local breath = player:GetAttribute("Breath")

	if breath then

		local maxBreath = getMaxBreath()

		local percent = breath / maxBreath
		breathFill.Size = UDim2.new(percent,0,1,0)

		breathText.Text = math.floor(breath).." / "..maxBreath

	end

end)


-- Depth UI
player:GetAttributeChangedSignal("Depth"):Connect(function()

	local depth = player:GetAttribute("Depth")

	if depth then
		depthText.Text = "Depth: "..depth.."m"
	end

end)


-- Reward popup
player:GetAttributeChangedSignal("Reward"):Connect(function()

	local reward = player:GetAttribute("Reward")

	if reward and reward > 0 then

		rewardText.Text = "+"..reward.." Coins"
		rewardText.Visible = true

		task.wait(2)

		rewardText.Visible = false

	end
	
	-- Update when upgrade changes
	local upgrades = player:WaitForChild("Upgrades")
	local breathLevel = upgrades:WaitForChild("BreathLevel")

	breathLevel.Changed:Connect(function()

		local breath = player:GetAttribute("Breath")

		if breath then
			local maxBreath = getMaxBreath()
			local percent = breath / maxBreath

			breathFill.Size = UDim2.new(percent,0,1,0)
			breathText.Text = math.floor(breath).." / "..maxBreath
		end

	end)

end)]]></ProtectedString>
